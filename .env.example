# MulikaScans — Environment Variables Template
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=your-super-secret-key-change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=0

# Supabase (Auth, Database, Storage)
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your-anon-key
# Service role key — server-side only, never expose to browser
SUPABASE_SERVICE_KEY=sb_secret_your-service-role-key
# Supabase Storage bucket name
SUPABASE_STORAGE_BUCKET=mulikaScan

# Database — Supabase PostgreSQL
# Get from: Supabase Dashboard → Project Settings → Database → Connection String
# Transaction Pooler (recommended for web apps):
DATABASE_URL=postgresql://postgres.nfyspkcmkaigqmnqdwte:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Or Direct Connection:
# DATABASE_URL=postgresql://postgres:[DB-PASSWORD]@db.nfyspkcmkaigqmnqdwte.supabase.co:5432/postgres

# JWT cookie max-age (seconds) — controls how long Supabase tokens are kept in cookies
# Access token: default 3600 (1 hour, matches Supabase default)
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# Email (Flask-Mail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@mulikascans.com

# ─── Flutterwave ─────────────────────────────────────────────────────────────
# Get keys from: https://dashboard.flutterwave.com/dashboard/settings/apis
# Use FLWSECK_TEST-... / FLWPUBK_TEST-... for testing
# Use FLWSECK-...    / FLWPUBK-...       for production
FLW_SECRET_KEY=FLWSECK_TEST-your-secret-key
FLW_PUBLIC_KEY=FLWPUBK_TEST-your-public-key
FLW_WEBHOOK_SECRET_HASH=your-custom-webhook-secret

# Flutterwave Payment Plan IDs
# Create at: Dashboard → Payment Plans → Create Plan
# Basic Monthly:  $29/mo  → interval=monthly
# Basic Annual:   $290/yr → interval=yearly
# Pro Monthly:    $79/mo  → interval=monthly
# Pro Annual:     $790/yr → interval=yearly
FLW_BASIC_MONTHLY_PLAN_ID=
FLW_BASIC_ANNUAL_PLAN_ID=
FLW_PRO_MONTHLY_PLAN_ID=
FLW_PRO_ANNUAL_PLAN_ID=

# Payment callback URL (must match your Flutterwave redirect_url)
PAYMENT_REDIRECT_URL=https://mulikascans.com/payment/callback

# Frontend URL (for email verification links)
FRONTEND_URL=https://mulikascans.com

# Session inactivity timeout (minutes — default 30)
SESSION_TIMEOUT_MINUTES=30

# Redis (optional — for Celery async scanning)
REDIS_URL=redis://localhost:6379/0

# SEO — Bing Webmaster Tools verification
# Get from: https://www.bing.com/webmasters → Add site → Verify → Meta tag value
BING_VERIFICATION=your-bing-verification-code

# IndexNow key (Bing fast-indexing — generate once with: python -c "import uuid; print(uuid.uuid4().hex)")
INDEXNOW_KEY=67fb14cc542d47fdada4048b4c3eb428
